# === Trading (Polymarket CLOB v2) ===
# paper = simulasyon | live = gercek emir
TRADING_MODE=live

# Cuzdan ozel anahtar (signer) — gercek emir icin zorunlu
PRIVATE_KEY=0x...

# Polymarket proxy / safe / EOA funder adresi (deposit adresi degil)
FUNDER_ADDRESS=0x...

# Signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271
SIGNATURE_TYPE=1

# Live ama emir gondermek istemiyorsan (sadece log) — sahte istek:
# TRADING_DRY_RUN=true

# Opsiyonel
# CLOB_HOST=https://clob.polymarket.com
# CHAIN_ID=137
# DEFAULT_ORDER_SIZE=6
